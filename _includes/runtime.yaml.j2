# =============================================================================
# RUNTIME — платформа и связь (НЕ лента)
# =============================================================================

esphome:
  name: {{ device_name }}
  friendly_name: "{{ friendly_name }}"
  project:
    name: "mihazzzold.espHome-Gimmer"
    version: "{{ firmware_version }}"
  on_boot:
    priority: -100
    then:
{% include "on_boot_ota_publish.yaml.j2" %}
  platformio_options:
    build_flags:
      - '-DSERIAL_NUMBER="{{ serial_number | default("UNKNOWN") }}"'

{% if chip_family == "esp8266" %}
esp8266:
  board: {{ board | default("nodemcuv2") }}
  restore_from_flash: true
{% else %}
esp32:
  board: {{ board | default("esp32-c3-devkitm-1") }}
  framework:
    type: {{ framework_type | default("arduino") }}
{% endif %}

{% include "runtime_network_ota.yaml.j2" %}
